From 3bee60cd83585c11ef76f3a3e21dc02fabdbd87b Mon Sep 17 00:00:00 2001
From: smartdev <smartdevs17@gmail.com>
Date: Sat, 25 Apr 2026 08:26:46 +0100
Subject: [PATCH] fix: address security issues - CSP headers, message
 sanitization, self-tipping prevention

- Add CSP headers to vercel.json and index.html for XSS prevention
- Add message validation in contract to reject control characters
- Add frontend self-tipping prevention with disabled tip button
- Already implemented: self-tipping prevention in contract (tips.rs:142-144)
- Already implemented: events for state-changing operations in events.rs

Closes #493
Closes #426
Closes #425
Closes #424
---
 contracts/tipz/src/errors.rs                  |  2 ++
 contracts/tipz/src/validation.rs              | 11 ++++++++
 frontend-scaffold/index.html                  |  1 +
 .../src/features/tipping/TipPage.tsx          | 27 +++++++++++++++----
 vercel.json                                   | 11 ++++++++
 5 files changed, 47 insertions(+), 5 deletions(-)

diff --git a/contracts/tipz/src/errors.rs b/contracts/tipz/src/errors.rs
index d65e67a..cf7b206 100644
--- a/contracts/tipz/src/errors.rs
+++ b/contracts/tipz/src/errors.rs
@@ -70,4 +70,6 @@ pub enum ContractError {
     AdminChangeTimelockNotMet = 31,
     /// A different admin change is already pending (cancel or wait before proposing another)
     AdminChangeAlreadyPending = 32,
+    /// Tip message contains invalid control characters
+    InvalidMessage = 33,
 }
diff --git a/contracts/tipz/src/validation.rs b/contracts/tipz/src/validation.rs
index 18a4517..9c25e03 100644
--- a/contracts/tipz/src/validation.rs
+++ b/contracts/tipz/src/validation.rs
@@ -307,5 +307,16 @@ pub fn validate_message(message: &String) -> Result<(), ContractError> {
         return Err(ContractError::MessageTooLong);
     }
 
+    if message.len() > 0 {
+        let mut buf = [0u8; 280];
+        let n = message.len() as usize;
+        message.copy_into_slice(&mut buf[..n]);
+        for &b in &buf[..n] {
+            if b < 0x20 && b != b'\n' && b != b'\t' && b != b'\r' {
+                return Err(ContractError::InvalidMessage);
+            }
+        }
+    }
+
     Ok(())
 }
