// Stellar Tipz — Prisma schema
//
// This is the STARTER schema. Most models are added/extended by individual issues
// (see the "data model" issues). Run `npm run prisma:migrate` after changing this file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A creator/user identified by their Stellar wallet address.
/// Extended by profile, credit, tips and other modules in later issues.
model User {
  id            String         @id @default(cuid())
  stellarAddress String        @unique
  username      String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
}

/// On-chain tip mirrored off-chain by the indexer.
/// Fields and relations are expanded in the tips/indexer issues.
model Tip {
  id           String   @id @default(cuid())
  txHash       String   @unique
  ledger       Int
  fromAddress  String
  toAddress    String
  amountStroops BigInt
  message      String?
  createdAt    DateTime @default(now())
  refund       Refund?
}

/// Tracks indexer progress per event topic so it can resume after a restart.
model IndexerCursor {
  topic       String   @id
  lastLedger  Int
  updatedAt   DateTime @updatedAt
}

/// Refund requests tied to a specific tip.
model Refund {
  id        String   @id @default(cuid())
  tipId     String   @unique
  tip       Tip      @relation(fields: [tipId], references: [id])
  amount    BigInt
  reason    String
  status    String   @default("pending")
  txHash    String?
  createdAt DateTime @default(now())
}

/// In-app notification for a user.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

/// Cached X (Twitter) account metrics.
model XAccount {
  id         String   @id @default(cuid())
  handle     String   @unique
  followers  Int      @default(0)
  engagement Float?
  fetchedAt  DateTime @default(now())
}
